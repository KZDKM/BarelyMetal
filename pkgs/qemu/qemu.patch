+        //if (ret < 0) {
+        //    error_setg(errp, "CPPC: Could not register the MPERF_RO/APERF_RO MSRs: %s",
+        //               strerror(-ret));
+        //    return false;
+        //}
+        cppc_msr_isset = true;
+    }
+    return true;
+}
