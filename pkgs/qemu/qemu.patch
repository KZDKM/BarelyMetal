+static void smbios_build_type_20_table(unsigned instance, uint64_t size)
+{
+    uint64_t start, end, start_kb, end_kb;
+    SMBIOS_BUILD_TABLE_PRE(20, T20_BASE + instance, true); /* required */
+    start = instance * size;
+    end = start + size - 1;
+    assert(end > start);
+    start_kb = start / KiB;
+    end_kb = end / KiB;
+    if (start_kb < UINT32_MAX && end_kb < UINT32_MAX) {
+        t->starting_address = cpu_to_le32(start_kb);
+        t->ending_address = cpu_to_le32(end_kb);
+        t->extended_starting_address = t->extended_ending_address = cpu_to_le64(0);
+    } else {
+        t->starting_address = t->ending_address = cpu_to_le32(UINT32_MAX);
+        t->extended_starting_address = cpu_to_le64(start);
+        t->extended_ending_address = cpu_to_le64(end);
+    }
+    t->memory_device_handle = cpu_to_le16(T17_BASE + instance);
+    t->memory_array_mapped_address_handle = cpu_to_le16(T19_BASE);
+    t->partition_row_position = 0xFF; /* Unknown */
+    t->interleave_position = 0; /* Not interleaved */
+    t->interleaved_data_depth = 0; /* Not interleaved */
+    SMBIOS_BUILD_TABLE_POST;
