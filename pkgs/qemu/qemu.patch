+static void get_pci_name(char *cstr, int devfn)
+{
+    int slot = PCI_SLOT(devfn);
+    int func = PCI_FUNC(devfn);
+    switch (slot) {
+        case 27:
+            if (func == 0) sprintf(cstr, "HDAS");
+            else sprintf(cstr, "AF%.02X", devfn);
+            break;
+        case 29:
+            sprintf(cstr, "EHC%X", func);
+            break;
+        case 31:
+            if (func == 0) sprintf(cstr, "LPCB");
+            else if (func == 2) sprintf(cstr, "SAT%X", func);
+            else if (func == 3) sprintf(cstr, "SBUS");
+            else sprintf(cstr, "AF%.02X", devfn);
+            break;
+        default:
+            sprintf(cstr, "AF%.02X", devfn);
+            break;
+    }
+}
